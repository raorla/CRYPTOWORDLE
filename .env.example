# --- ETH Sepolia deployment / round generator ---

# Sepolia RPC endpoint (Infura/Alchemy/public). Note: most public RPCs cap
# eth_getLogs at ~10k blocks — the app reads state via view functions instead
# of historical log scans for exactly that reason.
SEPOLIA_RPC_URL=

# Deployer + round-generator EOA private key (0x-prefixed).
# Use a FRESH dev key funded with Sepolia ETH — never a mainnet key.
# This wallet deploys the contract, creates rounds, and funds pots.
DEPLOYER_PRIVATE_KEY=

# Pot size (in ETH) the round generator attaches to each round.
ROUND_POT_ETH=0.01

# Round duration in seconds (deadline = now + this) — default 24h.
ROUND_DURATION_SECONDS=86400

# Deployed CryptoWordle address (written by scripts/deploy.ts into
# deployments/sepolia.json; set here to override).
CRYPTOWORDLE_ADDRESS=
